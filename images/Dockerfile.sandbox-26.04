# pats sandbox image: ubuntu 26.04 + agent harness clis.
# starts with claude-cli; codex-cli + opencode to follow.
#
# installed globally (npm -g -> /usr/*) so the cli is on PATH for ANY uid --
# pats runs the container with `--user <host uid>`, which has no home of its
# own, so a per-user install (~/.local) would be invisible/unwritable.
# pin CLAUDE_CLI_VERSION before publishing; floating `latest` for now.
FROM docker.io/library/ubuntu:26.04

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        nodejs \
        npm && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ARG CLAUDE_CLI_VERSION=latest
ARG OPENCODE_VERSION=latest
RUN npm install -g \
        "@anthropic-ai/claude-code@${CLAUDE_CLI_VERSION}" \
        "opencode-ai@${OPENCODE_VERSION}" && \
    npm cache clean --force

# TODO(lczyk): codex-cli.

CMD ["/bin/bash"]
